ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://itnext:itnext@db:5432/itnext

JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Used by docker-compose.prod.yml to bake the API URL into the frontend build
# (NEXT_PUBLIC_API_URL: http://${SERVER_IP}:8000/api/v1). Must be set before
# running `docker compose -f docker-compose.prod.yml build`, or the frontend
# ships with a broken (blank-host) API URL and every request fails.
SERVER_IP=

CORS_ORIGINS=["http://localhost:3000"]

GEMINI_API_KEY=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=cvs

# Used to build CV upload/download URLs while neither B2 nor Azure Blob is configured.
API_PUBLIC_URL=http://localhost:8000
CV_STORAGE_DIR=data/cvs

# Backblaze B2 — blank means CVs fall back to local disk (above). Set all
# four to switch CV storage to B2 (private bucket, no card required).
B2_ENDPOINT=
B2_REGION=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=cvs

PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true

# Google OAuth Web Client ID — blank means the "Continue with Google" button
# stays hidden, nothing else breaks.
GOOGLE_CLIENT_ID=
